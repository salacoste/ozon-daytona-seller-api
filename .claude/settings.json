{
    "permissions": {
      "deny": [
        "Read(.env)",
        "Read(**/.env*)",
        "Read(**/.secret*)",
        "Read(**/env*)",
        "Read(**/*.pem)",
        "Read(**/*.key)",
        "Read(**/*.crt)",
        "Read(**/*.cert)",
        "Read(**/secrets/**)",
        "Read(**/node_modules/**)",
        "Read(**/credentials/**)"
      ]
    },
    "hooks": {
      "PreToolUse": [
        {
          "matcher": "Bash",
          "hooks": [
            {
              "type": "command",
              "command": "uv run ~/.claude/hooks/log_pre_tool_use.py"
            }
          ]
        }
      ],
      "PostToolUse": [
        {
          "matcher": "Write|Edit|MultiEdit",
          "hooks": [
            {
              "type": "command",
              "command": "uv run ~/.claude/hooks/ts_lint.py"
            }
          ]
        }
      ],
      "Notification": [
        {
          "matcher": "",
          "hooks": [
            {
              "type": "command",
              "command": "uv run ~/.claude/hooks/play_audio.py"
            },
            {
              "type": "command",
              "command": "uv run ~/.claude/hooks/macos_notification.py"
            }
          ]
        }
      ],
      "Stop": [
        {
          "matcher": "",
          "hooks": [
            {
              "type": "command",
              "command": "uv run ~/.claude/hooks/play_audio.py"
            },
            {
              "type": "command",
              "command": "uv run ~/.claude/hooks/macos_notification.py"
            }
          ]
        }
      ]
    }
  }