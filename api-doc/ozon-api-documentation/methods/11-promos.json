          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/seller_apiGetSellerProductV1Request"
              },
              "example": {
                "action_id": 63337,
                "limit": 10,
                "offset": 0,
                "last_id": "bnVсbA=="
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Список товаров",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/seller_apiGetSellerProductV1Response"
                },
                "example": {
                  "result": {
                    "products": [
                      {
                        "id": 226,
                        "price": 250,
                        "action_price": 0,
                        "alert_max_action_price_failed": true,
                        "alert_max_action_price": 31,
                        "max_action_price": 175,
                        "add_mode": "NOT_SET",
                        "stock": 0,
                        "min_stock": 0
                      },
                      {
                        "id": 1366,
                        "price": 2300,
                        "action_price": 630,
                        "alert_max_action_price_failed": true,
                        "alert_max_action_price": 31,
                        "max_action_price": 770,
                        "add_mode": "MANUAL",
                        "stock": 0,
                        "min_stock": 0
